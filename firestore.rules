rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 跑馬燈常用句:每位老師只能讀寫自己的資料
    match /marquee-phrases/{userId} {
      allow read, write: if request.auth != null
                         && request.auth.uid == userId;
    }

    // Say the Word 卡組(未來):每位老師只能讀寫自己的資料
    match /say-the-word-decks/{userId}/{document=**} {
      allow read, write: if request.auth != null
                         && request.auth.uid == userId;
    }

    // Word Search 題目(未來):每位老師只能讀寫自己的資料
    match /word-search-games/{userId}/{document=**} {
      allow read, write: if request.auth != null
                         && request.auth.uid == userId;
    }

    // Word Search 雲端房間
    match /word-search-rooms/{roomCode} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
                    && request.resource.data.ownerUid == request.auth.uid;
      allow update, delete: if request.auth != null
                    && resource.data.ownerUid == request.auth.uid;

      match /scores/{seat} {
        allow read, write: if request.auth != null;
      }
    }

    // 作業清點矩陣同步房間:多裝置即時同步
    match /homework-matrix-rooms/{roomCode} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
                    && request.resource.data.ownerUid == request.auth.uid;
      // 多裝置同步:任何登入裝置都能更新狀態
      allow update: if request.auth != null;
      // 刪除房間僅限建立者
      allow delete: if request.auth != null
                    && resource.data.ownerUid == request.auth.uid;

      // 每日紀錄子集合:任何登入裝置都能讀寫
      match /days/{date} {
        allow read, write: if request.auth != null;
      }
    }

    // 其他全部拒絕
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
